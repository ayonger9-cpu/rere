#!/usr/bin/env bash
set -euo pipefail

CMD="${1:-}"
USER="${2:-}"
PASS="${3:-}"
IPLIMIT="${4:-2}"
QMODE="${5:-0}"
[[ "$IPLIMIT" != "1" ]] && IPLIMIT=2

DB_FILE="/usr/local/etc/xray/limit-ip.db"
QUOTA_SSH_DB="/usr/local/etc/quota-ssh.db"
QUOTA_SSH_LOCK="/var/lock/quota-ssh.lock"

# Quota mode → GB mapping. Bisa di-override via /usr/local/etc/quota-mode.conf:
#   QUOTA_MODE1_GB=100
#   QUOTA_MODE2_GB=250
QUOTA_MODE1_GB=100
QUOTA_MODE2_GB=250
MODE_CONF="/usr/local/etc/quota-mode.conf"
[[ -f "$MODE_CONF" ]] && . "$MODE_CONF"

quota_mb_for_mode() {
  case "$1" in
    1) echo $(( QUOTA_MODE1_GB * 1024 )) ;;
    2) echo $(( QUOTA_MODE2_GB * 1024 )) ;;
    *) echo 0 ;;
  esac
}

# Lock pake file yang sama dengan quota-ssh.sh (cron tracker), jadi write
# di sini ke-serialize sama cron tick — hindari race: cron snapshot DB →
# sshman ubah DB → cron mv tmp ke DB (overwrite sshman). Identik dgn fix
# di vmessman/vlessman/trojanman buat quota-xray.
_with_ssh_lock() {
  (
    flock -w 10 9 || { echo "ERROR: gagal acquire $QUOTA_SSH_LOCK" >&2; exit 1; }
    "$@"
  ) 9>"$QUOTA_SSH_LOCK"
}

_do_write_ssh_quota() {
  local user="$1" limit_mb="$2" rdate="$3" tmp
  tmp="$(mktemp)"
  awk -F'|' -v u="$user" 'BEGIN{OFS="|"} $1!=u {print}' "$QUOTA_SSH_DB" > "$tmp"
  echo "$user|$limit_mb|0|active|$rdate" >> "$tmp"
  mv "$tmp" "$QUOTA_SSH_DB"
}

_do_prune_ssh_quota() {
  local user="$1" tmp
  tmp="$(mktemp)"
  awk -F'|' -v u="$user" '$1!=u' "$QUOTA_SSH_DB" > "$tmp" && mv "$tmp" "$QUOTA_SSH_DB"
}

write_ssh_quota() {
  local user="$1" mode="$2" limit_mb rdate
  case "$mode" in
    0|"") return 0 ;;
    1|2) ;;
    *) echo "Quota mode '$mode' tidak valid (0/1/2)"; return 1 ;;
  esac
  limit_mb=$(quota_mb_for_mode "$mode")
  rdate="$(date -d 'next month' +%Y-%m-01 2>/dev/null || date +%Y-%m-01)"
  mkdir -p "$(dirname "$QUOTA_SSH_DB")" 2>/dev/null || true
  touch "$QUOTA_SSH_DB"
  _with_ssh_lock _do_write_ssh_quota "$user" "$limit_mb" "$rdate"
  echo "Quota SSH: ${limit_mb} MB (mode $mode)"
}

usage() {
  echo "Usage:"
  echo "  sshman add <username> <password> [iplimit 1/2] [mode 0/1/2]"
  echo "  sshman check <username>"
  echo "  sshman del <username>"
  echo "  sshman unlock <username>"
  echo ""
  echo "  mode 0 = tanpa quota (default)"
  echo "  mode 1 = ${QUOTA_MODE1_GB} GB"
  echo "  mode 2 = ${QUOTA_MODE2_GB} GB"
  echo "  Override default lewat /usr/local/etc/quota-mode.conf"
  exit 1
}

[[ -z "$CMD" || -z "${USER:-}" ]] && usage

if ! [[ "$USER" =~ ^[a-zA-Z0-9_]{3,32}$ ]]; then
  echo "Username invalid (a-zA-Z0-9_ panjang 3-32)"
  exit 1
fi

user_exists() { id "$USER" &>/dev/null; }

do_unlock() {
  passwd -u "$USER" &>/dev/null || true
  if command -v faillock &>/dev/null; then
    faillock --user "$USER" --reset &>/dev/null || true
  fi
  if command -v pam_tally2 &>/dev/null; then
    pam_tally2 -u "$USER" -r &>/dev/null || true
  fi
}

make_permanent() {
  chage -E -1 "$USER" &>/dev/null || true
  chage -M 99999 -m 0 -I -1 "$USER" &>/dev/null || true
}

case "$CMD" in
  add)
    [[ -z "${PASS:-}" ]] && usage
    user_exists && { echo "User already exists"; exit 1; }

    useradd -M -N -s /usr/sbin/nologin "$USER"
    echo "${USER}:${PASS}" | chpasswd

    make_permanent
    do_unlock
    mkdir -p "$(dirname "$DB_FILE")" 2>/dev/null || true
    touch "$DB_FILE" 2>/dev/null || true
    sed -i "/^$USER /d" "$DB_FILE" 2>/dev/null || true
    echo "$USER $IPLIMIT" >> "$DB_FILE"
    # write_ssh_quota di-serialize lewat _with_ssh_lock (flock on
    # /var/lock/quota-ssh.lock) supaya gak race sama cron quota-ssh.
    write_ssh_quota "$USER" "$QMODE" || { userdel "$USER" &>/dev/null || true; exit 1; }
    echo "Added SSH: $USER (limit: $IPLIMIT IP, mode: $QMODE)"
    ;;

  check)
    user_exists || { echo "Not found"; exit 1; }
    passwd -S "$USER" || true
    st="$(passwd -S "$USER" 2>/dev/null | awk '{print $2}' || true)"
    if [[ "$st" == "L" ]]; then
      echo "SSH LOCKED: $USER"
      echo "Coba: sshman unlock $USER"
      exit 0
    fi
    echo "SSH OK: $USER"
    ;;

  del)
    user_exists || { echo "Not found"; exit 1; }
    do_unlock
    userdel "$USER" &>/dev/null || true
    sed -i "/^$USER /d" "$DB_FILE" 2>/dev/null || true
    # userdel udah remove user dari /etc/passwd, jadi cron quota-ssh gak
    # bakal nge-track ulang user ini. Prune DB row dengan flock supaya
    # gak ke-race sama cron tick yg mungkin lagi jalan.
    if [[ -f "$QUOTA_SSH_DB" ]]; then
      _with_ssh_lock _do_prune_ssh_quota "$USER"
    fi
    echo "Deleted SSH: $USER"
    ;;

  unlock)
    user_exists || { echo "Not found"; exit 1; }
    do_unlock
    make_permanent
    passwd -S "$USER" || true
    echo "Unlocked SSH: $USER"
    ;;

  *) usage ;;
esac
